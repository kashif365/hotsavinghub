<IfModule mod_rewrite.c>

    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>
    
    RewriteEngine On
    Options -Indexes

    # 1. Force HTTPS + WWW for hotsavinghub.com
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} !^www\.hotsavinghub\.com$ [NC]
    RewriteRule ^(.*)$ https://www.hotsavinghub.com/$1 [L,R=301]

    # 2. Handle Authorization Headers (For API support)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # 3. Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # 4. FIX FOR 404s: Serve existing files/folders directly
    # This ensures CSS, JS, and images are loaded immediately if they exist.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 5. Redirect Trailing Slashes If Not A Folder
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 6. Send All Other Requests To index.php (Laravel)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

</IfModule>

# --- Performance Optimization (Gzip Compression) ---
<IfModule mod_deflate.c>
    <FilesMatch "\.(js|css|html|htm|php|xml|json|svg|ttf|otf)$">
        SetOutputFilter DEFLATE
    </FilesMatch>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml image/svg+xml image/x-icon
</IfModule>

# --- Browser Caching (Expires Headers) ---
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images & Favicon
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"

    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"

    # Prevent caching of HTML for real-time updates
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# --- Cache-Control Headers ---
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff|woff2|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    </FilesMatch>
    Header append Vary User-Agent
</IfModule>